{
  "name": "@husile/clawnet-web",
  "version": "0.1.0",
  "description": "ClawNet Web UI - Modern web interface for ClawNet management",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\""
  },
  "keywords": [
    "clawnet",
    "web-ui",
    "react",
    "typescript",
    "ant-design"
  ],
  "author": "husile",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bsheepcoder/ClawNet-Web.git"
  },
  "bugs": {
    "url": "https://github.com/Bsheepcoder/ClawNet-Web/issues"
  },
  "homepage": "https://github.com/Bsheepcoder/ClawNet-Web#readme",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "antd": "^5.15.0",
    "@ant-design/icons": "^5.3.0",
    "zustand": "^4.5.0",
    "axios": "^1.6.0",
    "socket.io-client": "^4.7.0",
    "dayjs": "^1.11.10",
    "@antv/g6": "^4.8.24"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0"
  }
}
