import React, { useState, useEffect } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import { Card, Descriptions, Tag, Space, Button, message, Tabs, Badge, Alert, Divider, Switch, Select, Input, Form, InputNumber } from 'antd';
import { WechatOutlined, ApiOutlined, LinkOutlined, ReloadOutlined } from '@ant-design/icons';
import { api } from '../services/api';

const { Option } = Select;
const { Item: FormItem } = Form;

interface InstanceData {
  id: string;
  name: string;
  port: number;
  status: 'running' | 'stopped';
  wechat?: {
    loggedIn: boolean;
    accountId?: string;
    userId?: string;
  };
  gateway?: {
    running: boolean;
    pid?: number;
    port: number;
  };
  clawnet?: {
    connected: boolean;
    nodeId?: string;
  };
  createdAt: string;
  config?: {
    model?: {
      primary: string;
      fallbacks: string[];
    };
    workspace?: string;
    channels?: string[];
    plugins?: string[];
    clawnet?: {
      forwardWechat: boolean;
      endpoint: string;
    };
    gateway?: {
      shared: boolean;
      port: number;
      bind: string;
    };
  };
}

const InstanceDetail: React.FC = () => {
  const { id } = useParams<{ id: string }>();
  const navigate = useNavigate();
  const [loading, setLoading] = useState(true);
  const [instance, setInstance] = useState<InstanceData | null>(null);
  const [activeTab, setActiveTab] = useState('overview');

  useEffect(() => {
    if (id) {
      fetchInstance();
    }
  }, [id]);

  const fetchInstance = async () => {
    if (!id) return;
    
    setLoading(true);
    try {
      const response = await api.get(`/instances/${id}`);
      if (response.data.success) {
        setInstance(response.data.data);
      } else {
        message.error('加载实例详情失败');
        navigate('/instances');
      }
    } catch (error) {
      console.error('Failed to fetch instance:', error);
      message.error('加载实例详情失败');
      navigate('/instances');
    } finally {
      setLoading(false);
    }
  };

  const handleConnect = async () => {
    if (!instance) return;
    
    try {
      const response = await api.post(`/instances/${instance.id}/connect`);
      if (response.data.success) {
        message.success('已连接到 ClawNet');
        fetchInstance();
      } else {
        message.error('连接失败');
      }
    } catch (error) {
      message.error('连接失败');
    }
  };

  if (loading) {
    return (
      <Card loading={loading}>
        <div style={{ height: 300 }} />
      </Card>
    );
  }

  if (!instance) {
    return <Alert message="实例不存在" type="error" />;
  }

  const tabItems = [
    {
      key: 'overview',
      label: '📊 概览',
      children: (
        <div>
          {/* 基本信息 */}
          <Card style={{ marginBottom: 16 }}>
            <Descriptions bordered column={2}>
              <Descriptions.Item label="实例名称">{instance.name}</Descriptions.Item>
              <Descriptions.Item label="状态">
                <Tag color={instance.status === 'running' ? 'success' : 'default'}>
                  {instance.status === 'running' ? '✅ 运行中' : '⏸️ 已停止'}
                </Tag>
              </Descriptions.Item>
              <Descriptions.Item label="Gateway">
                <Space>
                  <Tag color="blue">共享 Gateway</Tag>
                  <span>:18789</span>
                </Space>
              </Descriptions.Item>
              <Descriptions.Item label="创建时间">
                {new Date(instance.createdAt).toLocaleString('zh-CN')}
              </Descriptions.Item>
            </Descriptions>
          </Card>

          {/* 微信状态 */}
          <Card title="💬 微信状态" style={{ marginBottom: 16 }}>
            <Space>
              <WechatOutlined />
              <Tag color={instance.wechat?.loggedIn ? 'success' : 'default'}>
                {instance.wechat?.loggedIn ? '✅ 已登录' : '❌ 未登录'}
              </Tag>
              {instance.wechat?.accountId && (
                <span>账号: {instance.wechat.accountId}</span>
              )}
            </Space>
          </Card>

          {/* ClawNet 连接 */}
          <Card title="🔗 ClawNet 连接" style={{ marginBottom: 16 }}>
            <Space>
              <ApiOutlined />
              <Tag color={instance.clawnet?.connected ? 'success' : 'default'}>
                {instance.clawnet?.connected ? '✅ 已连接' : '❌ 未连接'}
              </Tag>
              {!instance.clawnet?.connected && (
                <Button type="primary" onClick={handleConnect}>
                  连接
                </Button>
              )}
            </Space>
          </Card>
        </div>
      ),
    },
    {
      key: 'config',
      label: '📝 配置',
      children: (
        <Alert
          message="配置编辑功能"
          description="详细配置编辑功能正在开发中，请通过 API 或配置文件进行修改。"
          type="info"
          showIcon
        />
      ),
    },
    {
      key: 'extensions',
      label: '🔌 扩展',
      children: (
        <Alert
          message="扩展管理功能"
          description="插件管理功能正在开发中。"
          type="info"
          showIcon
        />
      ),
    },
  ];

  return (
    <div>
      <Card
        title={`实例: ${instance.name}`}
        extra={
          <Button icon={<ReloadOutlined />} onClick={fetchInstance}>
            刷新
          </Button>
        }
      >
        <Tabs
          activeKey={activeTab}
          onChange={setActiveTab}
          items={tabItems}
        />
      </Card>
    </div>
  );
};

export default InstanceDetail;
